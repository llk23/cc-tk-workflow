# ==============================
# TK AI Video Pipeline — 环境变量
# ==============================

# ---- 数据库 (SQL Server) ----
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourPassword123!
DB_NAME=tk_workflow

# ---- Redis (BullMQ 任务队列) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Server ----
SERVER_PORT=3000

# ---- AI Provider (按需配置) ----
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Claude
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- TK API ----
# TikAPI / 第三方 TK 数据 API
TK_API_BASE_URL=https://api.example.com
TK_API_KEY=your-tk-api-key

# ---- 视频生成工具 ----
# 你的 AI 视频生成工具 API
VIDEO_GEN_API_URL=https://api.videogen.example.com
VIDEO_GEN_API_KEY=your-videogen-key
