# ==============================
# TK AI Video Pipeline — 环境变量
# ==============================

# ---- 数据库 (SQL Server) ----
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourPassword123!
DB_NAME=tk_workflow

# ---- Redis (BullMQ 任务队列) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- MongoDB (结构化分析报告存储) ----
MONGO_URL=mongodb://mongoadmin:mongoadmin@localhost:27017/tk_workflow?authSource=admin

# ---- MinIO (S3 兼容对象存储：视频/音频/抽帧) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
# 未配置 MINIO_ENDPOINT 时，系统自动回退到本地文件系统存储(见 apps/server StorageModule)
MINIO_PUBLIC_URL=http://localhost:9000

# ---- Server ----
SERVER_PORT=3000

# ---- AI Provider (按需配置) ----
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Claude
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- TK API ----
# TikAPI / 第三方 TK 数据 API
TK_API_BASE_URL=https://api.example.com
TK_API_KEY=your-tk-api-key

# ---- 视频生成工具 ----
# 你的 AI 视频生成工具 API
VIDEO_GEN_API_URL=https://api.videogen.example.com
VIDEO_GEN_API_KEY=your-videogen-key
